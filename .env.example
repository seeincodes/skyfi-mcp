# SkyFi API
SKYFI_API_KEY=
SKYFI_API_BASE_URL=https://app.skyfi.com/platform-api
SKYFI_API_VERSION=2026-03

# Simulation
SKYFI_SIMULATE=false

# Server (remote mode)
PORT=8787
RATE_LIMIT_PER_MIN=100
BURST_LIMIT=20
DAILY_ORDER_CAP=10
DAILY_SPEND_CAP_USD=10000

# Guardrails
AOI_MAX_AREA_ARCHIVE_KM2=50000
AOI_MAX_AREA_TASKING_KM2=10000
PRICE_WARN_THRESHOLD_USD=500
# PRICE_HARD_LIMIT_USD=          # Optional: uncomment to enable hard price rejection

# Pre-Authorized Mode (all three required to activate)
PREAUTH_ENABLED=false
# PREAUTH_MAX_ORDER_USD=
# PREAUTH_MONTHLY_LIMIT_USD=
# PREAUTH_ALLOWED_AOI=           # GeoJSON polygon string

# Observability
LOG_LEVEL=INFO

# Cloudflare (remote deployment only)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
