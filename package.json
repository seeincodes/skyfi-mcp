{
  "name": "skyfi-mcp",
  "version": "0.1.0",
  "description": "Official SkyFi MCP server — satellite imagery tools for AI agents",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "skyfi-mcp": "dist/stdio.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/ tests/ --format json",
    "lint:fix": "eslint src/ tests/ --fix --format json",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test",
    "status:refresh": "bash scripts/generate-status.sh"
  },
  "keywords": [
    "mcp",
    "skyfi",
    "satellite",
    "imagery",
    "geospatial",
    "ai-agents"
  ],
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@turf/turf": "^7.3.4",
    "hono": "^4.12.8",
    "zod": "^4.3.6"
  }
}
